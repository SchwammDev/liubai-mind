#!/usr/bin/env bash
# Daily driver: the pinned pi engine + aqueduct model + steering rails, runnable
# from any working directory. Rails load globally (see setup.sh); the model and
# provider come from this repo's config. Run `setup.sh` once before first use.
#
# Steering is on by default. For the un-steered baseline: LIUBAI_RAILS_OFF=1 liubai ...
set -euo pipefail

REPO="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
PI_BIN="$REPO/node_modules/.bin/pi"

command -v mise >/dev/null 2>&1 || { echo "liubai: mise not found — run $REPO/setup.sh" >&2; exit 1; }
[ -x "$PI_BIN" ] || { echo "liubai: engine not installed — run $REPO/setup.sh" >&2; exit 1; }

exec mise exec -- "$PI_BIN" \
  --provider aqueduct \
  --model aqueduct/qwen-3.5-397b \
  "$@"
